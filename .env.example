# ── EUMETSAT ────────────────────────────────────────────────────────────────
EUMETSAT_CONSUMER_KEY=
EUMETSAT_CONSUMER_SECRET=
EUM_COLLECTION=EO:EUM:DAT:0682

# ── NASA FIRMS ──────────────────────────────────────────────────────────────
FIRMS_MAP_KEY=

# ── Telerivet (SMS alerts) ──────────────────────────────────────────────────
TELERIVET_API_KEY=
TELERIVET_PROJECT_ID=
TELERIVET_GROUP_ID=

# ── Alert settings ──────────────────────────────────────────────────────────
ALERT_TO=               # E.164 format, e.g. +263772000000
MIN_CONFIDENCE=0.5
LOOKBACK_HOURS=2
POLL_INTERVAL_SECONDS=900

# ── Frontend ─────────────────────────────────────────────────────────────────
# Set to the public-facing URL of your backend (IP or hostname of the Docker host)
NEXT_PUBLIC_API_URL=http://YOUR_SERVER_IP:8000
